            dataType: string
            id: drift_data
          outgoingConnections:
            - data->"Prompt" re_prompt/drift_analysis
          visualData: 100/200/250/1//

        '[re_input_ma]:graphInput "Macro Analysis"':
          data:
            dataType: string
            id: macro_analysis
          outgoingConnections:
            - data->"Prompt" re_prompt/macro_context
          visualData: 100/450/250/2//

        '[re_input_rp]:graphInput "Risk Profile"':
          data:
            dataType: string
            id: risk_profile
          outgoingConnections:
            - data->"Prompt" re_prompt/risk_context
          visualData: 100/700/250/3//

        '[re_prompt]:prompt "Generate Recommendations"':
          data:
            enableFunctionCall: false
            promptText: |
              ## CVM-Compliant Recommendations

              You are a CVM-compliant investment advisor at XP Investimentos.

              CRITICAL RULES:
              - NEVER use "compre", "venda", "recomendo a compra/venda"
              - Use: "pode ser oportuno avaliar", "a alocacao sugere ajuste"
              - NEVER guarantee returns
              - Always frame as analysis, not direct recommendations

              ### Drift Analysis (calculated by Python/pandas — numbers are EXACT):
              {{drift_analysis}}

              ### Client Risk Profile:
              {{risk_context}}

              ### Macro Context (from Agent 2):
              {{macro_context}}

              Generate 3-5 specific rebalancing suggestions in Portuguese.
              Reference the exact drift percentages and amounts.
              Max 300 words.
            type: user
            useTypeInput: false
          outgoingConnections:
            - output->"Chat" re_chat/prompt
          visualData: 500/400/350/4//

        '[re_chat]:chat "GPT-4o"':
          data:
            cache: false
            enableFunctionUse: false
            maxTokens: 1000
            model: gpt-4o
            temperature: 0.3
            top_p: 1
            useAsGraphPartialOutput: false
          outgoingConnections:
            - response->"GraphOutput" re_output/value
          visualData: 950/400/250/5//

        '[re_output]:graphOutput "Recommendations"':
          data:
            dataType: string
            id: output
          visualData: 1250/400/200/6//

