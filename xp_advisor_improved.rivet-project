    # ─── SUBGRAPH: PORTFOLIO ANALYST ──────────────────────────────────────
    agent_portfolio_analyst:
      metadata:
        description: "Receives pre-calculated portfolio metrics (from Python/pandas) and generates a narrative summary with GPT-4o."
        id: agent_portfolio_analyst
        name: "Agent 1: Portfolio Analyst"
      nodes:
        '[pa_input]:graphInput "Portfolio Data"':
          data:
            dataType: string
            id: portfolio_data
          outgoingConnections:
            - data->"Prompt" pa_prompt/calculated_metrics
          visualData: 100/300/250/1//

        '[pa_prompt]:prompt "Summarize Portfolio"':
          data:
            enableFunctionCall: false
            promptText: |
              ## Portfolio Analysis Summary

              You are a financial analyst at XP Investimentos.
              The JSON below contains EXACT metrics calculated by Python/pandas code.
              Use ONLY these numbers. Never invent or estimate figures.

              ### Calculated Portfolio Metrics (JSON — computed by Python/pandas):
              {{calculated_metrics}}

              ### Instructions:
              - Highlight overall return vs CDI and IBOV benchmarks
              - Flag any positions with extreme losses (>25%) or gains (>30%)
              - Note the asset allocation breakdown (renda_fixa vs acoes)
              - Include LAST MONTH stock returns (monthly_change_pct field) calculated from the profitability CSV
              - Keep it factual and data-driven, max 250 words
            type: user
            useTypeInput: false
          outgoingConnections:
            - output->"Chat" pa_chat/prompt
          visualData: 450/300/350/2//

        '[pa_chat]:chat "GPT-4o"':
          data:
            cache: false
            enableFunctionUse: false
            maxTokens: 800
            model: gpt-4o
            temperature: 0.2
            top_p: 1
            useAsGraphPartialOutput: false
          outgoingConnections:
            - response->"GraphOutput" pa_output/value
          visualData: 900/300/250/3//

        '[pa_output]:graphOutput "Portfolio Analysis"':
          data:
            dataType: string
            id: output
          visualData: 1200/300/200/4//

    # ─── SUBGRAPH: MACRO ANALYST ──────────────────────────────────────────
    agent_macro_analyst:
      metadata:
        description: "Reads XP's macro report, extracts key projections (Selic, IPCA, GDP, FX)."
        id: agent_macro_analyst
        name: "Agent 2: Macro Analyst"
      nodes:
        '[ma_input]:graphInput "Macro Report"':
          data:
            dataType: string
            id: macro_report
          outgoingConnections:
            - data->"Prompt" ma_prompt/macroeconomic_report
          visualData: 100/300/250/1//

        '[ma_prompt]:prompt "Analyze Macro"':
          data:
            enableFunctionCall: false
            promptText: |
              ## Macroeconomic Analysis

              You are a senior macroeconomic analyst at XP Investimentos.
              Analyze the monthly macro research report below and extract:

              1. KEY PROJECTIONS: Selic path, IPCA forecast, GDP growth, BRL/USD
              2. MARKET SENTIMENT: Assessment for each asset class
              3. PORTFOLIO IMPLICATIONS: What this means for fixed income, equities, FIIs
              4. RISK FACTORS: Top 3-5 risks to monitor

              Keep it factual, data-driven, max 400 words.

              ### Report:
              {{macroeconomic_report}}
            type: user
            useTypeInput: false
          outgoingConnections:
            - output->"Chat" ma_chat/prompt
          visualData: 450/300/300/2//

        '[ma_chat]:chat "GPT-4o"':
