      metadata:
        description: "In production, uses python-docx. For demo, passes letter through."
        id: agent_doc_formatter
        name: "Agent 6: Doc Formatter"
      nodes:
        '[df_input]:graphInput "Reviewed Letter"':
          data:
            dataType: string
            id: reviewed_letter
          outgoingConnections:
            - data->"GraphOutput" df_output/value
          visualData: 100/300/250/1//

        '[df_output]:graphOutput "Final Document"':
          data:
            dataType: string
            id: output
          visualData: 450/300/200/2//

