        '[lw_input_rp]:graphInput "Risk Profile"':
          data:
            dataType: string
            id: risk_profile
          outgoingConnections:
            - data->"Prompt" lw_prompt/risk_profile
          visualData: 100/900/250/5//

        '[lw_prompt]:prompt "Write Letter"':
          data:
            enableFunctionCall: false
            promptText: |
              ## Monthly Investment Letter (Portuguese)

              Write a professional monthly investment letter in Brazilian Portuguese.
              Max 2 pages (~600 words). Letter format with paragraphs.

              STRUCTURE:
              1. Header: "Carta Mensal de Investimentos — Fevereiro/2026"
              2. Greeting: "Prezado Albert,"
              3. Market context (1-2 paragraphs)
              4. Portfolio performance with EXACT numbers from the JSON data
              5. Individual stock monthly returns (monthly_change_pct from CSV data) — mention at least the most notable movers
              6. Positioning and outlook
              7. CVM-compliant recommendations (which assets to consider adding/reducing)
              8. Professional closing with "Atenciosamente, Carlos Eduardo Martins, CNPI-T 12345"
              9. Disclaimer: "Este material e meramente informativo e nao constitui recomendacao de investimento."

              ### Client Risk Profile:
              {{risk_profile}}

              ### Portfolio Data (JSON — exact numbers from Python/pandas):
              {{portfolio_analysis}}

              ### Portfolio Narrative (from Agent 1):
              {{portfolio_narrative}}

              ### Macro Analysis (from Agent 2):
              {{macro_analysis}}

              ### Recommendations (from Agent 3):
              {{recommendations}}
            type: user
            useTypeInput: false
          outgoingConnections:
            - output->"Chat" lw_chat/prompt
          visualData: 500/450/400/6//

        '[lw_chat]:chat "GPT-4o"':
          data:
            cache: false
            enableFunctionUse: false
            maxTokens: 2000
            model: gpt-4o
            temperature: 0.4
            top_p: 1
            useAsGraphPartialOutput: false
          outgoingConnections:
            - response->"GraphOutput" lw_output/value
          visualData: 1000/450/250/7//

        '[lw_output]:graphOutput "Letter Text"':
          data:
            dataType: string
            id: output
          visualData: 1300/450/200/8//

    # ─── SUBGRAPH: COMPLIANCE REVIEWER ────────────────────────────────────
    agent_compliance_reviewer:
      metadata:
        description: "Reviews letter for CVM compliance — quality gate."
        id: agent_compliance_reviewer
        name: "Agent 5: Compliance Reviewer"
      nodes:
        '[cr_input]:graphInput "Letter Text"':
          data:
            dataType: string
            id: letter_text
          outgoingConnections:
            - data->"Prompt" cr_prompt/letter_text
          visualData: 100/300/250/1//

        '[cr_prompt]:prompt "Review Compliance"':
          data:
            enableFunctionCall: false
            promptText: |
              ## CVM Compliance Review

              Review this investment letter for regulatory compliance:

              CHECK FOR:
              1. Direct buy/sell language ("compre", "venda", "recomendo a compra")
              2. Guaranteed returns ("vai render", "garantido", "sem risco")
              3. Missing disclaimer about risks
              4. Misleading comparisons
              5. Aggressive/pressuring tone

              OUTPUT: PASS/FAIL, list of violations, suggested fixes, score 0-100.

              ### Letter:
              {{letter_text}}
            type: user
            useTypeInput: false
          outgoingConnections:
            - output->"Chat" cr_chat/prompt
          visualData: 450/300/350/2//

        '[cr_chat]:chat "GPT-4o"':
          data:
            cache: false
            enableFunctionUse: false
            maxTokens: 800
            model: gpt-4o
            temperature: 0.1
            top_p: 1
            useAsGraphPartialOutput: false
          outgoingConnections:
            - response->"GraphOutput" cr_output/value
          visualData: 900/300/250/3//

        '[cr_output]:graphOutput "Reviewed Letter"':
          data:
            dataType: string
            id: output
          visualData: 1500/300/200/5//

