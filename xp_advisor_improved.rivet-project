            cache: false
            enableFunctionUse: false
            maxTokens: 1200
            model: gpt-4o
            temperature: 0.2
            top_p: 1
            useAsGraphPartialOutput: false
          outgoingConnections:
            - response->"GraphOutput" ma_output/value
          visualData: 850/300/250/3//

        '[ma_output]:graphOutput "Macro Analysis"':
          data:
            dataType: string
            id: output
          visualData: 1150/300/200/4//

    # ─── SUBGRAPH: RECOMMENDATION ENGINE ─────────────────────────────────
